#: ../scriptor:47
msgid "Usage:"
msgstr "გამოყენება:"

#: ../scriptor:47
msgid "[-h] [-r reader] [-p protocol] [-u] [file]\n"
msgstr "[-h] [-r წამკითხველი] [-p პროტოკოლი] [-u] [ფაილი]\n"

#: ../scriptor:48
msgid "          -h: this help\n"
msgstr "          -h: ეს დახმარება\n"

#: ../scriptor:49
msgid "   -r reader: specify to use the PCSC smart card reader named reader\n"
msgstr "   -r reader: მითითება, გამოყენებული იქნას PCSC ჭკვიანი ბარათის წამკითხველი სახელით reader\n"

#: ../scriptor:50
msgid "              By defaults the first one found is used so you\n"
msgstr "              ნაგულისხმევად გამოიყენება პირველი აღმოჩენილი. ასე რომ, თქვენ\n"

#: ../scriptor:51
msgid "              don't have to specify anything if you just have\n"
msgstr "              არაფრის მითითება არ გჭირდებათ, თუ გაქვთ, მხოლოდ,\n"

#: ../scriptor:52
msgid "              one reader\n"
msgstr "              ერთი წამკითხველი\n"

#: ../scriptor:53
msgid " -p protocol: protocol to use among T=0 and T=1.\n"
msgstr " -p protocol: გამოყენებული პროტოკოლი T=0-სა და T=1-ს შორის.\n"

#: ../scriptor:54
msgid "              Default is to let pcsc-lite choose the protocol\n"
msgstr "              ნაგულისხმევად pcsc-lite თვითონ ირჩევს პროტოკოლს\n"

#: ../scriptor:55
msgid "          -u: use unbuffered stdout\n"
msgstr "          -u: უბუფერო stdout-ის გამოყენება\n"

#: ../scriptor:56
msgid "        file: file containing APDUs\n"
msgstr "        ფაილი: APDU-ების შემცველი ფაილი\n"
